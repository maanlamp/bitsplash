{
	"$schema": "./node_modules/oxlint/configuration_schema.json",
	"plugins": ["typescript", "unicorn", "oxc"],
	"jsPlugins": ["./require-default-fields-oxc-plugin.ts"],
	"categories": {
		"correctness": "error"
	},
	"rules": {
		"curly": ["error", "all"],
		"func-style": [
			"error",
			"expression",
			{ "allowArrowFunctions": true }
		],
		"ecs-conventions/require-default-fields": "error"
	},
	"env": {
		"builtin": true
	},
	"options": {
		"typeAware": true,
		"typeCheck": true
	},
	"overrides": [
		{
			"files": ["src/engine/**"],
			"rules": {
				"no-restricted-imports": [
					"error",
					{
						"patterns": [
							{
								"group": ["**/game/**", "**/editor/**"],
								"message": "Engine must not import from the game or editor layers (README dependency rule)."
							}
						]
					}
				]
			}
		},
		{
			"files": ["src/editor/**"],
			"rules": {
				"no-restricted-imports": [
					"error",
					{
						"patterns": [
							{
								"group": ["**/game/**"],
								"message": "Editor must not import from the game layer (README dependency rule)."
							}
						]
					}
				]
			}
		}
	]
}
